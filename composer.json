{
    "name": "blendbyte/filament-title-with-slug",
    "description": "Title + slug field for Filament v5 with auto-slug generation, live permalink preview, and inline editing.",
    "keywords": [
        "framework",
        "laravel",
        "filament",
        "slug",
        "permalink",
        "livewire",
        "alpinejs",
    ],
    "homepage": "https://github.com/blendbyte/filament-title-with-slug",
    "license": "MIT",
    "authors": [
        {
            "name": "Andreas Scheibel",
            "email": "contact@camya.com",
            "role": "Developer",
            "homepage": "https://www.camya.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/larastan": "^3.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Blendbyte\\FilamentTitleWithSlug\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Blendbyte\\FilamentTitleWithSlug\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "preflight": "vendor/bin/pint && vendor/bin/phpstan analyse && vendor/bin/pest",
        "format": "vendor/bin/pint"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Blendbyte\\FilamentTitleWithSlug\\FilamentTitleWithSlugServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
